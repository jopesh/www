---
import type { CollectionEntry } from "astro:content";
import BlurImage from "../components/blur-image.astro";
import PostDate from "../components/post-date.astro";
import Base from "./base.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<Base title={title} description={description} class="pt-8">
  <article>
    {heroImage && (
      <BlurImage
        alt=""
        class="mb-10"
        height={510}
        src={heroImage}
        width={1020}
      />
    )}
    <header class="mb-12">
      <PostDate
        date={pubDate}
        updatedDate={updatedDate}
        class="mb-4 text-sm tracking-wide uppercase text-text-muted"
      />
      <h2
        class="flex font-serif text-3xl font-light leading-tight text-text md:text-4xl"
      >
        {title}
      </h2>
      <div class="mt-8 flex items-center gap-4" aria-hidden="true">
        <span class="h-px flex-1 bg-border" />
        <span class="text-text-muted/40 text-xs">&#x2767;</span>
        <span class="h-px flex-1 bg-border" />
      </div>
    </header>
    <div
      class="prose-article prose prose-bq-rule prose-base max-w-none text-text-light"
    >
      <slot />
    </div>
  </article>
</Base>
