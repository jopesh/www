---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import PostDate from "../components/post-date.astro";
import PostTitle from "../components/post-title.astro";
import Base from "./base.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<Base title={title} description={description} class="pt-8">
  <article>
    {heroImage && (
                    <div class="mb-10">
                        <Image
                            alt=""
                            class="w-full"
                            height={510}
                            src={heroImage}
                            width={1020}
                        />
                    </div>
                )}
    <div class="mb-10">
      <PostDate
        date={pubDate}
        updatedDate={updatedDate}
        class="mb-4 text-sm text-text-muted"
      />
      <PostTitle
        class="font-serif text-2xl font-light leading-tight text-text md:text-3xl"
        title={title}
      />
    </div>
    <div
      class="prose prose-base max-w-none text-text-light prose-p:leading-relaxed prose-strong:text-text prose-strong:font-medium prose-blockquote:border-accent/30 prose-blockquote:font-serif prose-blockquote:text-text-muted prose-blockquote:not-italic prose-hr:border-border prose-code:text-text prose-code:font-normal prose-img:rounded-sm prose-lead:text-text-light prose-figcaption:text-text-muted prose-a:underline prose-a:underline-offset-2 prose-a:decoration-text-muted/40 prose-a:hover:text-accent prose-a:hover:decoration-accent/40 prose-headings:font-serif prose-headings:font-light prose-headings:text-text"
    >
      <slot />
    </div>
  </article>
</Base>
