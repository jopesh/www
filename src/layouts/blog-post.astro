---
import type { CollectionEntry } from "astro:content";
import BlurImage from "../components/blur-image.astro";
import PostDate from "../components/post-date.astro";
import PostTitle from "../components/post-title.astro";
import Base from "./base.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<Base title={title} description={description} class="pt-8">
  <article>
    {heroImage && (
      <BlurImage
        alt=""
        class="mb-10"
        height={510}
        src={heroImage}
        width={1020}
      />
    )}
    <div class="mb-10">
      <PostDate
        date={pubDate}
        updatedDate={updatedDate}
        class="mb-4 text-sm text-text-muted"
      />
      <PostTitle
        class="font-serif text-2xl font-light leading-tight text-text md:text-3xl"
        title={title}
      />
    </div>
    <div
      class="prose prose-base max-w-none text-text-light prose-headings:font-serif prose-headings:font-light prose-headings:text-text prose-headings:tracking-tight prose-p:leading-relaxed prose-a:text-text prose-a:underline prose-a:underline-offset-2 prose-a:decoration-text-muted/40 prose-a:[text-decoration-thickness:1px] prose-a:transition-colors prose-a:duration-200 prose-a:hover:text-accent prose-a:hover:decoration-accent/40 prose-strong:text-text prose-strong:font-medium prose-blockquote:border-accent/30 prose-blockquote:[border-left-width:2px] prose-blockquote:font-serif prose-blockquote:text-text-muted prose-blockquote:not-italic prose-blockquote:text-lg prose-blockquote:leading-relaxed prose-blockquote:font-light prose-hr:border-border prose-hr:my-12 prose-code:text-text prose-code:font-normal prose-pre:bg-paper-dark prose-pre:text-text-light prose-pre:border prose-pre:border-border prose-pre:rounded-md prose-img:rounded-sm prose-lead:text-text-light prose-figcaption:text-text-muted prose-figcaption:text-center prose-th:border-border prose-td:border-border prose-li:marker:text-text-muted"
    >
      <slot />
    </div>
  </article>
</Base>
