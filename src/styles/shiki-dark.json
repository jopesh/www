{
  "name": "paper-dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1c1c10",
    "editor.foreground": "#e5e2d0"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#787660", "fontStyle": "italic" }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": { "foreground": "#9ab83a" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#8aaa38" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#c8a835" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": { "foreground": "#5ab898" }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.class"
      ],
      "settings": { "foreground": "#a888d8" }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "meta.definition.variable"
      ],
      "settings": { "foreground": "#e5e2d0" }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag", "meta.tag"],
      "settings": { "foreground": "#8aaa38" }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": { "foreground": "#5ab898" }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": { "foreground": "#c0bd9a" }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": { "foreground": "#c0bd9a" }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#c0bd9a" }
    },
    {
      "scope": ["constant.other.color", "support.constant"],
      "settings": { "foreground": "#c8a835" }
    },
    {
      "scope": ["entity.other.inherited-class", "support.type.builtin"],
      "settings": { "foreground": "#a888d8" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#8aaa38" }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#a888d8" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#8aaa38", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#9ab83a" }
    }
  ]
}
